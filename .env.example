# Plantilla de variables de entorno. Copia este archivo como `.env.local`
# y reemplaza los valores con los de tu proyecto de Supabase
# (Supabase → Project Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Google Books API — clave gratuita, solo servidor (opcional; sin ella se usa Open Library).
GOOGLE_BOOKS_API_KEY=
